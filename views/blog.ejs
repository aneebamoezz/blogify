<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Blog</title>
</head>
<body>
    <%- include('./partials/nav') %>
      <div class="container mt-4">
        <h1><%= blog.title %></h1>
        <img src="<%= blog.coverImgURL %>" width="700px" alt="">
        <p><%= blog.body %></p>
      </div>
      <div class="container mt-4">
        <img src="<%= blog.createdBy.profileImgURL %>" width="50px" alt=""><%= blog.createdBy.fullName %>
      </div>

      <div class="container mt-3">
        <% if (locals.user) { %>
        <h4>Comments (<%= comments.length %>)</h4>
         <form action="/blog/comment/<%= blog._id %>" method="post">
          <div class="mb-3">
              <input type="text" class="form-control" name="content" placeholder="Enter your comment">
              <button type="submit" class="btn btn-sm btn-primary mt-2">Add</button>
          </div>
        </form>

        <div class="mt-3">
          <% comments.forEach(comment => { %>
            <div>
              <img src="<%= comment.createdBy.profileImgURL %>" width="50px" alt=""><%= comment.createdBy.fullName %>
              <p><%= comment.content %></p>
            </div>
          <% }) %>
        </div>
        <% } %>
      </div>
    <%- include('./partials/script') %>
</body>
</html>